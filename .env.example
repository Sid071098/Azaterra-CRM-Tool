# ─── Database (REQUIRED) ──────────────────────────────────────────────
# Postgres connection string. Get this from Neon / Vercel Postgres /
# Supabase / Railway. Must start with postgresql:// (or postgres://).
# Vercel Postgres also exposes POSTGRES_PRISMA_URL — point DATABASE_URL
# at the pooled URL for serverless functions.
DATABASE_URL="postgresql://user:password@host:5432/azaterra?sslmode=require"

# ─── App URL (used by Gmail OAuth redirect) ───────────────────────────
# Production: https://azaterracrm.com
# Preview deploys: leave the Vercel default
NEXT_PUBLIC_APP_URL="https://azaterracrm.com"

# ─── Supabase (OPTIONAL — only if using the supabase-backed inquiry path) ──
# NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# ─── OpenAI follow-up email generation (OPTIONAL) ────────────────────
# Without these the API falls back to a deterministic template.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# ─── Company research for the AI follow-up (OPTIONAL) ────────────────
# Any HTTP API that returns JSON with summary/description/snippet fields.
# COMPANY_SEARCH_API_URL=https://api.example.com/search
# COMPANY_SEARCH_API_KEY=...

# ─── Gmail send-from-rep (OPTIONAL but recommended) ──────────────────
# Create OAuth credentials at https://console.cloud.google.com
# Authorized redirect URI must exactly equal GOOGLE_REDIRECT_URI.
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_REDIRECT_URI=https://azaterracrm.com/api/email/google/callback

# ─── Brochure URL shown in WhatsApp follow-ups (OPTIONAL) ────────────
# NEXT_PUBLIC_BROCHURE_URL=https://azaterra.com/

# ─── WhatsBoost WhatsApp automation (OPTIONAL) ───────────────────────
# When WHATSBOOST_API_KEY is set, new manual CRM inquiries and newly
# inserted IndiaMART leads will automatically send a WhatsApp message.
# WHATSBOOST_API_KEY=...
# WHATSBOOST_ACCOUNT_ID=...
# WHATSBOOST_BASE_URL=https://whatsboost.net
# WHATSAPP_DEFAULT_COUNTRY_CODE=91
# WHATSAPP_AUTO_SEND_ON_NEW_LEAD=true

# ─── IndiaMART Gmail sync ───────────────────────────────────────────
# Uses the connected Gmail account to pull original IndiaMART lead emails.
# Defaults are usually enough:
# Optional extra Gmail query. The app also runs built-in IndiaMART buyer-lead searches.
# INDIAMART_GMAIL_QUERY=from:indiamart.com
# INDIAMART_GMAIL_MAX_RESULTS=20
# INDIAMART_GMAIL_AUTO_IMPORT=true
# INDIAMART_DUPLICATE_WINDOW_DAYS=30
